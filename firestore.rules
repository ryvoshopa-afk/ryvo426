rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Under full-stack server-side proxy architecture, the Express server handles 
    // all user verification, endpoint protection, and validation checks.
    // Therefore, the database permits administrative read/write access.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
